# Props Oracle — environment variables
# Copy to .env and fill in values. Never commit .env.

# Chain config — defaults to Base Sepolia (Coinbase L2, chain 84532)
# Override all four to switch to Ethereum Sepolia or another chain
# CHAIN_RPC_URL=https://sepolia.base.org
# CHAIN_ID=84532
# CHAIN_NAME=Base Sepolia
# CHAIN_EXPLORER=https://sepolia.basescan.org

# On-chain certificate registry
CONTRACT_ADDRESS=0x07a7c1efc53923b202191a888fad41e54cae7ca6
PRIVATE_KEY=0x_YOUR_DEPLOYER_KEY_HERE

# Oracle target (medical_board | attorney)
ORACLE_TARGET=medical_board

# LLM model
OLLAMA_MODEL=llama3.2:3b
